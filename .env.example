# Shared API profile.
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_TYPE=openai

# Optional role-specific overrides. Leave blank to use the shared profile.
MEMORY_API_KEY=
MEMORY_BASE_URL=
MEMORY_MODEL=
MEMORY_API_TYPE=

RESEARCH_API_KEY=
RESEARCH_BASE_URL=
RESEARCH_MODEL=
RESEARCH_API_TYPE=

WORKING_API_KEY=
WORKING_BASE_URL=
WORKING_MODEL=
WORKING_API_TYPE=

JUDGE_API_KEY=
JUDGE_BASE_URL=
JUDGE_MODEL=
JUDGE_API_TYPE=

# Local embedding model used by dense retrieval and token-aware chunking.
MEMPRO_MODEL_BACKEND=api
MEMPRO_EMBEDDING_MODEL=BAAI/bge-m3
MEMPRO_DENSE_DEVICES=cuda:0

# Runtime parallelism.
MEMPRO_QUESTION_WORKERS=1
MEMPRO_MEMORY_WORKERS=1
MEMPRO_NUM_WORKERS=1
